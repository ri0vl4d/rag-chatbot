# Copy this file to .env and fill in real values. NEVER commit .env.

# NVIDIA NIM (free) — sign up at https://build.nvidia.com and generate an API key.
NVIDIA_API_KEY=nvapi-REPLACE_ME
# 8b answers in ~2s on the free tier; 70b can queue for minutes.
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Embeddings (local — no key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval + chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
RETRIEVER_K=4

# LLM behavior
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Data
DATA_DIR=data

# CORS (comma-separated). For local dev include Vite. For prod add your Render frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Simple bearer token to protect /api/reindex. Change this for production.
REINDEX_TOKEN=change-me
